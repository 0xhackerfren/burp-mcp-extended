root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.{kt,kts}]
indent_size = 4
max_line_length = 120

[*.{yml,yaml}]
indent_size = 2

[*.{json,json.example}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{toml,properties}]
indent_size = 4

[gradlew.bat]
end_of_line = crlf
